+        const sphere = ctx.createRadialGradient(cx-R*.28,cy-R*.28,0, cx,cy,R);
+        sphere.addColorStop(0,   `rgba(220,210,255,${.97*ya})`);
+        sphere.addColorStop(0.38,`rgba(124,58,237,${.88*ya})`);
+        sphere.addColorStop(1,   `rgba(20,5,50,${.75*ya})`);
+        ctx.fillStyle = sphere;
+        ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2); ctx.fill();
+      }
+
+      // Specular highlight (shared)
+      const spec = ctx.createRadialGradient(cx-R*.52,cy-R*.50,0, cx-R*.35,cy-R*.35,R*.55);
