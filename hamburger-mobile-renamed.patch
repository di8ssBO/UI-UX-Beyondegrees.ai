+    cSpeed: (0.45+Math.random()*0.55)*(Math.random()<.5?1:-1),
+  }));
+
+  const cvs = document.getElementById('mcCanvas');
+  if (!cvs) return;
+  const ctx = cvs.getContext('2d');
+  const W = 160, H = 160, cx = W/2, cy = H/2, ORBIT_R = 46, CYCLE = 6000;
+  ctx.scale(2, 2);
+  let t0 = null;
+
+  function frame(now) {
+    if (!t0) t0 = now;
+    const abs = (now-t0)/1000;
+    const cyc = (now-t0) % CYCLE;
+    ctx.clearRect(0,0,W,H);
+
+    const settleP   = ez(rng(cyc, CYCLE*.15, CYCLE*.42));
+    const convergeP = eo3(rng(cyc, CYCLE*.42, CYCLE*.57));
+    const youP      = eo3(rng(cyc, CYCLE*.57, CYCLE*.76));
+    const youFadeP  = rng(cyc, CYCLE*.76, CYCLE*.85);
+    const scatterP  = eo3(rng(cyc, CYCLE*.83, CYCLE*.95));
+    const dimP      = rng(cyc, CYCLE*.95, CYCLE);
+
+    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
+
+    // Icon fades in when dots settle into orbit, fades out as they converge
+    const iconAlpha = clp((settleP - 0.5) * 2, 0, 1) * clp(1 - convergeP * 2.5, 0, 1) * (scatterP > 0 ? 0 : 1);
+
+    tokens.forEach((tk,i) => {
+      const chaosA   = tk.chaos0 + tk.cSpeed*abs;
+      const settledA = TGT_A[i];
+      let da = settledA - chaosA;
+      da = ((da+Math.PI*3)%(Math.PI*2)) - Math.PI;
+      const displayA = scatterP>0 ? mix(settledA,chaosA,scatterP) : mix(chaosA,chaosA+da,settleP);
+      const displayDist = scatterP>0
+        ? mix(0,tk.cDist,scatterP)
+        : mix(mix(tk.cDist,ORBIT_R,settleP),0,convergeP);
+      const x = cx + displayDist*Math.cos(displayA);
+      const y = cy + displayDist*Math.sin(displayA);
+      const alpha = (scatterP>0 ? scatterP : (1-convergeP))*(1-dimP*.6);
+      const col = isLight ? COLORS_LIGHT[i] : COLORS[i];
+
+      if (isLight) {
+        ctx.save();
+        // Soft glow halo
+        // Soft color glow behind chip
+        ctx.globalAlpha = Math.max(0, alpha) * 0.15;
+        const glow = ctx.createRadialGradient(x,y,5,x,y,26);
+        glow.addColorStop(0, col);
+        glow.addColorStop(1, 'rgba(0,0,0,0)');
+        ctx.fillStyle = glow;
+        ctx.beginPath(); ctx.arc(x,y,26,0,Math.PI*2); ctx.fill();
+        // Frosted glass white chip
+        ctx.globalAlpha = Math.max(0, alpha) * 0.92;
+        ctx.fillStyle = 'rgba(255,255,255,0.95)';
+        ctx.beginPath(); ctx.arc(x,y,17,0,Math.PI*2); ctx.fill();
