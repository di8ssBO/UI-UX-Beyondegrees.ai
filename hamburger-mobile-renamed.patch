+        ctx.globalAlpha = Math.max(0, alpha);
+        ctx.font = "14px sans-serif";
+        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
+        ctx.fillText(ICONS[i], x, y + 1);
+        ctx.restore();
+      } else {
+        ctx.save();
+        // Colored glow halo
+        ctx.globalAlpha = alpha * 0.22;
+        const glowD = ctx.createRadialGradient(x,y,5,x,y,26);
+        glowD.addColorStop(0, col);
+        glowD.addColorStop(1, 'rgba(0,0,0,0)');
+        ctx.fillStyle = glowD;
+        ctx.beginPath(); ctx.arc(x,y,26,0,Math.PI*2); ctx.fill();
+        // Dark glass chip GÇö neutral background so icon always pops
+        ctx.globalAlpha = Math.max(0, alpha) * 0.88;
+        ctx.fillStyle = 'rgba(12,10,30,0.90)';
+        ctx.beginPath(); ctx.arc(x,y,17,0,Math.PI*2); ctx.fill();
+        // Colored border ring
+        ctx.globalAlpha = Math.max(0, alpha) * 0.75;
+        ctx.strokeStyle = col;
+        ctx.lineWidth = 2;
+        ctx.beginPath(); ctx.arc(x,y,17,0,Math.PI*2); ctx.stroke();
+        // Icon GÇö always visible on dark neutral background
+        ctx.globalAlpha = Math.max(0, alpha);
+        ctx.font = "14px sans-serif";
+        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
+        ctx.fillText(ICONS[i], x, y + 1);
+        ctx.restore();
+      }
+    });
+
+    // Dashed orbit ring
+    if (settleP>.15 && convergeP<.8) {
+      ctx.save();
+      ctx.strokeStyle = `rgba(167,139,250,${Math.min(settleP,1-convergeP)*.22})`;
+      ctx.lineWidth = .5; ctx.setLineDash([3,6]);
