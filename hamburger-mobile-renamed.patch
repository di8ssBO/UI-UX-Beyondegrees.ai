+<script>
+(function () {
+  /* "YOU" word GÇö translated per active language */
+  const YOU_WORDS = { en:'YOU', vi:'Bß¦áN', hi:'añåañ¬', fr:'TOI', ar:'+ú+å+¬' };
+  function getYouWord() {
