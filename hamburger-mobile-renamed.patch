+  /* GöÇGöÇ Avatar bottom sheet GöÇGöÇ */
+  const camBtn       = document.getElementById('avatarCamBtn');
+  const fileInput    = document.getElementById('avatarFileInput');
+  const backdrop     = document.getElementById('avatarSheetBackdrop');
+  const sheet        = document.getElementById('avatarSheet');
+  const btnLibrary   = document.getElementById('sheetChooseLibrary');
+  const btnCamera    = document.getElementById('sheetTakePhoto');
+  const btnRemove    = document.getElementById('sheetRemovePhoto');
+  const btnCancel    = document.getElementById('sheetCancel');
+
+  function openSheet() {
+    backdrop.classList.add('open');
+    sheet.classList.add('open');
+  }
+  function closeSheet() {
+    backdrop.classList.remove('open');
+    sheet.classList.remove('open');
+  }
+
+  /* Camera icon GåÆ open sheet */
+  if (camBtn) camBtn.addEventListener('click', openSheet);
+
+  /* Backdrop tap / Cancel GåÆ close */
+  if (backdrop) backdrop.addEventListener('click', closeSheet);
+  if (btnCancel) btnCancel.addEventListener('click', closeSheet);
+
+  /* Handle file selected (shared by both library + take photo) */
+  function handleFile(file) {
+    if (!file) return;
+    var reader = new FileReader();
+    reader.onload = function (e) {
+      if (window.BDProfile) {
+        BDProfile.saveAvatar(e.target.result);
+        BDProfile.applyAvatar();
+      }
+    };
+    reader.readAsDataURL(file);
+    fileInput.value = '';
+  }
+
+  /* Option 1: Choose from Library */
+  if (btnLibrary) btnLibrary.addEventListener('click', function () {
+    closeSheet();
+    fileInput.removeAttribute('capture');
+    fileInput.accept = 'image/*';
+    setTimeout(function () { fileInput.click(); }, 300);
+  });
+
+  /* Option 2: Take Photo (mobile camera) */
+  if (btnCamera) btnCamera.addEventListener('click', function () {
+    closeSheet();
+    fileInput.setAttribute('capture', 'user');
+    fileInput.accept = 'image/*';
+    setTimeout(function () { fileInput.click(); }, 300);
+  });
+
+  /* Option 3: Remove Photo */
+  if (btnRemove) btnRemove.addEventListener('click', function () {
+    closeSheet();
+    if (window.BDProfile) {
+      BDProfile.removeAvatar();
+      BDProfile.applyAvatar();
+    }
+  });
+
+  /* File input change */
+  if (fileInput) fileInput.addEventListener('change', function () {
+    handleFile(fileInput.files && fileInput.files[0]);
+  });
 });
 </script>
 </body>
