+
+  const COLORS       = ['#8b5cf6','#06d6a0','#60a5fa','#fbbf24','#c084fc','#22d3ee'];
+  const COLORS_LIGHT = ['#7c3aed','#059669','#2563eb','#d97706','#db2777','#0891b2'];
+  const ICONS        = ['=ƒÆ+','GÜòn+Å','=ƒôû','=ƒî¦','=ƒîì','=ƒö¼'];
+  /* Discipline abbreviations GÇö language-dependent */
+  const LABELS_MAP = {
+    en: ['KN','HE','PR','LA','SO','NA'],
+    vi: ['KT','YT','NV','NN','XH','TN'],
+    hi: ['añ£aÑìañPañ+','añ+aÑìañ¦añ+','añ¦aÑìañ»añòaÑì','añ¡añ+','añ+añ+','añ¬aÑìañ¦'],
+    fr: ['CO','SA','PE','LA','SO','NA'],
+    ar: ['+à+¦','+¦+¡','+¦+«','+ä+¦','+º+¼','+++¿']
+  };
+  function getLabels() {
+    var lang; try { lang = localStorage.getItem('bd-lang') || 'en'; } catch(e) { lang = 'en'; }
+    return LABELS_MAP[lang] || LABELS_MAP.en;
+  }
+  const LABELS = getLabels();
+  const TGT_A  = COLORS.map((_,i) => (i*60-90)*Math.PI/180);
+  function lightenHex(hex, amt) {
+    const n = parseInt(hex.slice(1),16);
+    const r = Math.min(255, ((n>>16)&255) + Math.round(255*amt));
+    const g = Math.min(255, ((n>>8)&255)  + Math.round(255*amt));
+    const b = Math.min(255, (n&255)       + Math.round(255*amt));
+    return `rgb(${r},${g},${b})`;
+  }
+  function darkenHex(hex, amt) {
+    const n = parseInt(hex.slice(1),16);
+    const r = Math.max(0, ((n>>16)&255) - Math.round(255*amt));
+    const g = Math.max(0, ((n>>8)&255)  - Math.round(255*amt));
+    const b = Math.max(0, (n&255)       - Math.round(255*amt));
+    return `rgb(${r},${g},${b})`;
+  }
+  const ez  = p => p<.5 ? 2*p*p : 1-(-2*p+2)**2/2;
+  const eo3 = p => 1-(1-p)**3;
+  const clp = (v,a,b) => Math.max(a,Math.min(b,v));
+  const rng = (t,a,b) => clp((t-a)/(b-a),0,1);
+  const mix = (a,b,t) => a+(b-a)*t;
+
+  const tokens = LABELS.map((label,i) => ({
