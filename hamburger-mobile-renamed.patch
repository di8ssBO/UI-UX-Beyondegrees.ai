+
+      if (isLight) {
+        // Light mode: purple sphere GÇö keep purple per spec, softer halo (-13%)
+        const halo = ctx.createRadialGradient(cx,cy,R*.6,cx,cy,R*1.6);
+        halo.addColorStop(0, `rgba(205,164,255,${.19*ya})`);
